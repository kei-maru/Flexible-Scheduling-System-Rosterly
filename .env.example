# =========================================================
# Veludo + Rosterly 单文件 .env 完整模板（A/B 统一）
# =========================================================
# 使用建议：
# 1) 本文件支持“本地联调”和“线上域名”两套值，默认已填本地联调。
# 2) 改 .env 后请用 force-recreate（restart 不会重载 env_file）。
#    docker compose up -d --no-deps --force-recreate system_a system-b worker
# 3) SSO 切流顺序：A_LOGIN_MODE=hybrid -> 验证稳定 -> A_LOGIN_MODE=sso

# -----------------------------
# Django 基础
# -----------------------------
DEBUG=False
SECRET_KEY=please-change-me
SITE_ID=1
ALLOWED_HOSTS=161.33.129.157,localhost,vr-veludo.com,www.vr-veludo.com,rosterlyreverse.com,www.rosterlyreverse.com,api.rosterlyreverse.com,api.vr-veludo.com

# -----------------------------
# Database / Redis
# 注意：system-b 在 docker-compose.yml 中会覆盖 DB_NAME=saas_db
# -----------------------------
DB_NAME=veludo_db
DB_USER=veludo_user
DB_PASSWORD=zym02060
DB_HOST=db
DB_PORT=5432

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# -----------------------------
# System A -> System B Integration
# -----------------------------
SYSTEM_B_ROOT=http://system-b:8001
SAAS_API_URL=http://system-b:8001/api/v1/integration
SAAS_API_KEY=veludo_secret_key_123
SAAS_API_KEY_HEADER=X-Tenant-Key

CAST_SOURCE=remote
CAST_SOURCE_FALLBACK_LOCAL=True

# -----------------------------
# System A 登录模式（消费 B 的 SSO）
# -----------------------------
# legacy | hybrid | sso
A_LOGIN_MODE=hybrid

# ===== 本地联调（默认启用） =====
# A 对外基地址（用于 callback 拼接）
SYSTEM_A_BASE_URL=http://localhost:8000

# A 作为 SSO Client 的凭据（与 B 端白名单一致）
SYSTEM_B_SSO_CLIENT_ID=veludo-system-a
SYSTEM_B_SSO_CLIENT_SECRET=please-change-me

# A 调用 B 的 SSO 端点
# 注意：authorize 是浏览器跳转地址（本机可访问）
#      exchange 是 A 容器服务端调用地址（需容器内可访问）
SYSTEM_B_SSO_AUTHORIZE_URL=http://localhost:8001/sso/authorize
SYSTEM_B_SSO_EXCHANGE_URL=http://system-b:8001/api/v1/auth/sso/exchange
SYSTEM_B_IDENTITY_URL=http://system-b:8001/api/v1/integration/identity

# ===== 线上域名（需要上线时切换） =====
# SYSTEM_A_BASE_URL=https://vr-veludo.com
# SYSTEM_B_SSO_AUTHORIZE_URL=https://api.rosterlyreverse.com/sso/authorize
# SYSTEM_B_SSO_EXCHANGE_URL=https://api.rosterlyreverse.com/api/v1/auth/sso/exchange

# -----------------------------
# System B 作为统一身份源（IdP）
# -----------------------------
# 把你当前 System A 的 Discord Key 挪到这里（A 侧后续不用）
SYSTEM_B_DISCORD_CLIENT_ID=
SYSTEM_B_DISCORD_SECRET=
SYSTEM_B_DISCORD_KEY=
SYSTEM_B_DISCORD_AUTH_PROMPT=consent

# Discord Developer Portal 里必须配置这个 Callback URL（B 的 allauth 回调）
# 本地联调: http://localhost:8001/accounts/discord/login/callback/
# 线上环境: https://api.vr-veludo.com/accounts/discord/login/callback/

# SSO 授权码 TTL（秒）
SYSTEM_B_SSO_CODE_TTL_SECONDS=60

# B 侧允许的 A 回调地址白名单（逗号分隔）
# 这就是你说的“在 B 里面加 callback url”
SYSTEM_B_SSO_REDIRECT_URIS=http://localhost:8000/accounts/sso/callback

# 线上环境白名单示例
# SYSTEM_B_SSO_REDIRECT_URIS=https://vr-veludo.com/accounts/sso/callback

# A 侧 legacy Discord 登录参数（仅 fallback 场景）
SYSTEM_A_DISCORD_AUTH_PROMPT=consent

# 可选：多客户端 JSON 配置（存在时优先）
# SYSTEM_B_SSO_CLIENTS={"veludo-system-a":{"client_secret":"please-change-me","redirect_uris":["https://vr-veludo.com/accounts/sso/callback"]}}

# -----------------------------
# 邮件（System B）
# -----------------------------
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# -----------------------------
# VRChat / 其他保留项
# -----------------------------
VRC_USERNAME=
VRC_PASSWORD=
VRC_TOTP_SECRET=
VRC_GROUP_ID=
VRC_PURCHASE_CACHE_TTL=300

# 兼容入口（当前仍以 Tenant.api_key 数据库校验为准）
TENANT_API_KEY=veludo_secret_key_123
